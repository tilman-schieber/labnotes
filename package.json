{
  "name": "lab-notebook-prototype",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch server/index.mjs",
    "server": "node server/index.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "db:migrate": "node scripts/db/migrate.mjs",
    "db:status": "node scripts/db/status.mjs",
    "db:seed": "node scripts/db/seed.mjs",
    "db:bootstrap": "node scripts/db/bootstrap.mjs",
    "db:dump": "node scripts/db/dump.mjs",
    "db:restore": "node scripts/db/restore.mjs",
    "db:sync": "node scripts/db/sync.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-mention": "^2.11.5",
    "@tiptap/extension-table": "^2.11.5",
    "@tiptap/extension-table-cell": "^2.11.5",
    "@tiptap/extension-table-header": "^2.11.5",
    "@tiptap/extension-table-row": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
